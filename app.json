{
  "expo": {
    "name": "Kisan-Marg",
    "slug": "Kisan-Marg",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6aaa49"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rudradev.kisanmarg"
    },
    "android": {
      "package": "com.rudradev.kisanmarg",
      "permissions": [
        "INTERNET"
      ],
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#6aaa49"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing"
    ]
  }
}