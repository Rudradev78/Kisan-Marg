{
  "expo": {
    "name": "Kisan-Marg",
    "slug": "Kisan-Marg",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6aaa49"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rudradev.kisanmarg",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Kisan Marg needs your location to show your farm on the map.",
        "NSPhotoLibraryUsageDescription": "Kisan Marg needs access to save receipts to your gallery."
      }
    },
    "android": {
      "package": "com.rudradev.kisanmarg",
      "permissions": [
        "INTERNET",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "MEDIA_LIBRARY"
      ],
      "usesCleartextTraffic": true,
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY_HERE"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#6aaa49"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sharing",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Kisan Marg to save receipts to your photos.",
          "savePhotosPermission": "Allow Kisan Marg to save receipts to your photos.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Kisan Marg to use your location for the farm map."
        }
      ]
    ]
  }
}